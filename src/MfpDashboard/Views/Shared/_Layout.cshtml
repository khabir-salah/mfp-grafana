<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MFP Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="nav-inner">
            <a href="/" class="logo">
                <span class="logo-icon">◈</span>
                <span class="logo-text">MFP<span class="logo-accent">Dashboard</span></span>
            </a>
            <div class="nav-links">
                <a href="/" class="nav-link">Overview</a>
                <a href="#upload-section" class="nav-link">Upload</a>
                <a href="@ViewBag.GrafanaUrl" target="_blank" class="nav-cta">
                    Open Grafana ↗
                </a>
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <span>MFP Dashboard — Running on Linux · Grafana · PostgreSQL</span>
            <span class="footer-time" id="footer-time"></span>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
