{
  "uid": "mfp-exercise",
  "title": "MFP — Exercise",
  "description": "Calories burned, workout frequency, exercise breakdown",
  "tags": ["mfp", "exercise", "fitness"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg Calories Burned / day",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 200 }, { "color": "orange", "value": 600 }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
          "rawSql": "SELECT NOW() AS time, ROUND(AVG(calories_burned)::numeric, 0) AS \"Avg Burned\" FROM daily_summaries WHERE $__timeFilter(date::timestamp) AND calories_burned > 0;",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Workout Sessions",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
          "rawSql": "SELECT NOW() AS time, COUNT(*) AS \"Sessions\" FROM exercise_entries WHERE $__timeFilter(date::timestamp);",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Minutes Exercised",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "m" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
          "rawSql": "SELECT NOW() AS time, COALESCE(SUM(minutes), 0) AS \"Total Minutes\" FROM exercise_entries WHERE $__timeFilter(date::timestamp);",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Calories Burned",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "kcal", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
          "rawSql": "SELECT NOW() AS time, ROUND(SUM(calories_burned)::numeric, 0) AS \"Total Burned\" FROM exercise_entries WHERE $__timeFilter(date::timestamp);",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Calories Burned Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "kcal",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "#73BF69" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
          "rawSql": "SELECT date::timestamp AS time, SUM(calories_burned) AS \"Calories Burned\" FROM exercise_entries WHERE $__timeFilter(date::timestamp) GROUP BY date ORDER BY date;",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Exercise Minutes Per Day",
      "gridPos": { "x": 0, "y": 13, "w": 16, "h": 8 },
      "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
      "options": { "xTickLabelRotation": -45, "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "m", "color": { "mode": "fixed", "fixedColor": "#5794F2" } } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
          "rawSql": "SELECT date::timestamp AS time, SUM(minutes) AS \"Minutes\" FROM exercise_entries WHERE $__timeFilter(date::timestamp) GROUP BY date ORDER BY date;",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top Exercises by Calories Burned",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mfp-postgres-ds" },
          "rawSql": "SELECT exercise_name AS \"Exercise\", COUNT(*) AS \"Sessions\", ROUND(SUM(calories_burned)::numeric, 0) AS \"Total kcal\", ROUND(AVG(minutes)::numeric, 0) AS \"Avg Min\" FROM exercise_entries WHERE $__timeFilter(date::timestamp) GROUP BY exercise_name ORDER BY SUM(calories_burned) DESC LIMIT 10;",
          "format": "table"
        }
      ]
    }
  ]
}
